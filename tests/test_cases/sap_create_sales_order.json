{
  "suite_id": "SUITE-SAP-SALES-001",
  "suite_name": "SAP VA01 – Create Sales Order",
  "environment": "test",
  "browser": "chromium",
  "headless": false,
  "parallel": false,
  "test_cases": [
    {
      "test_id": "TC-SALES-ORDER-001",
