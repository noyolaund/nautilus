        {
          "step_id": "S005",
          "name": "Initial screenshot",
          "action": "screenshot",
          "timeout_ms": 10000,
          "retry_count": 0
        },
        {
          "step_id": "S003",
          "name": "Search button",
          "action": "click",
          "target": {
            "description": "in the 'Open Search' button",
