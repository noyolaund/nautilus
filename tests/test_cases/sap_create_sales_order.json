          "data": {
            "value": "https://erp.jnj.com/",
            "sensitive": false
          },
          "timeout_ms": 30000,
          "retry_count": 1,
          "pre_wait_ms": 0
        },
        {
          "step_id": "S002",
          "name": "Enter username",
          "action": "type",
          "target": {
            "description": "in the 'Email' field",
            "selector_strategy": "ai"
          },
          "data": {
            "value": "jnoyolam@its.jnj.com",
            "sensitive": false
          },
          "timeout_ms": 30000,
          "retry_count": 1,
          "pre_wait_ms": 0
        },
        {
          "step_id": "S003",
          "name": "Login button",
          "action": "click",
          "target": {
            "description": "in the 'Next' button",
            "selector_strategy": "ai"
          },
          "timeout_ms": 30000,
          "retry_count": 1,
          "pre_wait_ms": 0
        },
        {
          "step_id": "S004",
          "name": "Navigate to SAP ERP",
