          "timeout_ms": 20000,
          "retry_count": 1
        },
        {
          "step_id": "S010",
          "name": "Fill Customer Reference",
          "action": "type",
          "target": {
            "description": "in the 'Customer Reference' field",
            "selector_strategy": "ai"
          },
          "data": {
            "value": "0022",
            "sensitive": false
          },
          "timeout_ms": 20000,
          "retry_count": 1
        },
        {
          "step_id": "S011",
          "name": "Enter Material",
          "action": "type",
          "target": {
            "description": "in the first cell under the column 'Enter Material'",
            "selector_strategy": "ai"
          },
          "data": {
            "value": "3541158-13",
            "sensitive": false
          },
          "timeout_ms": 20000,
          "retry_count": 1
        },
        {
          "step_id": "S012",
          "name": "Enter Quantity",
          "action": "type",
          "target": {
            "description": "in the first cell under 'Enter Quantity'",
            "selector_strategy": "ai"
          },
          "data": {
            "value": "1",
            "sensitive": false
          },
          "timeout_ms": 20000,
          "retry_count": 1
