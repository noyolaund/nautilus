        {
          "step_id": "S014",
          "name": "Capture Document Number",
          "action": "extract",
          "target": {
            "description": "the document number from the bottom message",
            "selector_strategy": "ai"
          },
          "output": {
            "variable_name": "documentNumber",
            "source": "confirmation_message"
          },
          "timeout_ms": 20000,
          "retry_count": 0
        },
        {
          "step_id": "S015",
          "name": "Final screenshot",
          "action": "screenshot",
          "timeout_ms": 10000,
          "retry_count": 0
        }
