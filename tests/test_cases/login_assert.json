{
  "suite_id": "SUITE-JDE-RPT-001",
  "suite_name": "JDE E1 — Login (EDO to DPS)",
  "environment": "production",
  "browser": "chromium",
  "headless": false,
  "llm_provider": "anthropic",
  "llm_model": "claude-sonnet-4-20250514",
  "parallel": false,

  "test_cases": [
    {
      "test_id": "TC-login_assert",
      "name": "Copy report version - ",
      "description": "Copy report version",
      "tags": ["jde", "report_version", "copy", "data_driven"],
      "platform": "jde_e1",
      "base_url": "http://e1w0000036.jnj.com:9222/jde/E1Menu.maf",
      "preconditions": "User is logged into JDE. Report exists.",
      "priority": "high",
      "steps": [
        {
          "step_id": "S001",
          "name": "Navigate to JDE EnterpriseOne",
          "action": "navigate",
          "data": {
            "value": "http://e1w0000036.jnj.com:9222/jde/E1Menu.maf",
            "sensitive": false
          },
          "timeout_ms": 10000,
          "retry_count": 2,
          "pre_wait_ms": 0
        },
        {
          "step_id": "S002",
          "name": "Enter username",
          "action": "type",
          "target": {
            "description": "in the 'User' field",
            "selector_strategy": "ai"
          },
          "data": {
            "value": "jnoyolam",
            "sensitive": true
          },
          "timeout_ms": 3000,
          "retry_count": 2,
          "pre_wait_ms": 500,
          "screenshot_on_failure": true
        },
        {
          "step_id": "S003",
          "name": "Enter password",
          "action": "type",
          "target": {
            "description": "password in the Password field",
            "selector_strategy": "ai"
          },
          "data": {
            "value": "AmdsamI8!",
            "sensitive": true
          },
          "timeout_ms": 3000,
          "retry_count": 2,
          "pre_wait_ms": 500,
          "screenshot_on_failure": true
        },
        {
          "step_id": "S004",
          "name": "Login",
          "action": "click",
          "target": {
            "description": "the 'Sign In' button",
            "selector_strategy": "ai"
          },
          "timeout_ms": 3000,
          "retry_count": 2,
          "pre_wait_ms": 500,
          "screenshot_on_failure": true
        },
        {
          "step_id": "S005",
          "name": "Screenshot order confirmation",
          "action": "screenshot",
          "timeout_ms": 5000,
          "retry_count": 0
        },
        {
          "step_id": "S006",
          "name": "Login Assert",
          "action": "assert_visible",
          "target": {
            "description": "Welcome!",
            "selector_strategy": "ai"
          },
          "timeout_ms": 1000,
          "retry_count": 2,
          "pre_wait_ms": 500,
          "screenshot_on_failure": true
        }
      ],
      "expected_result": "Version is created successfully with title 'DPS'"
    }
  ]
}
