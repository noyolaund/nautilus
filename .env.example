# =============================================================================
# QA Automation Framework — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# Supported: anthropic, openai
LLM_PROVIDER=anthropic
LLM_API_KEY=your-api-key-here
LLM_MODEL=claude-sonnet-4-20250514

# --- API Server --------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
# Secret key for API authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
API_SECRET_KEY=change-me-to-a-random-secret
# Comma-separated list of allowed CORS origins (use * only for development)
CORS_ORIGINS=http://localhost:3000

# --- Browser -----------------------------------------------------------------
BROWSER_HEADLESS=true
BROWSER_SLOW_MO=0

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Stagehand ---------------------------------------------------------------
# Point to the Azure proxy instead of a real Stagehand server
STAGEHAND_SERVER_URL=http://localhost:3456

# --- Azure OpenAI Proxy -----------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://genaiapimna.jnj.com/openai-chat
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
PROXY_PORT=3456
