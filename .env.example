# =============================================================================
# QA Automation Framework — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# Supported: anthropic, openai
LLM_PROVIDER=anthropic
LLM_API_KEY=your-api-key-here
LLM_MODEL=claude-sonnet-4-20250514

# --- API Server --------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
# Secret key for API authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
API_SECRET_KEY=change-me-to-a-random-secret
# Comma-separated list of allowed CORS origins (use * only for development)
CORS_ORIGINS=http://localhost:3000

# --- Browser -----------------------------------------------------------------
BROWSER_HEADLESS=true
BROWSER_SLOW_MO=0
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Stagehand ---------------------------------------------------------------
# Point to the Azure proxy instead of a real Stagehand server
STAGEHAND_SERVER_URL=http://localhost:3456

# --- LLM Proxy --------------------------------------------------------------
PROXY_LLM_ENDPOINT=https://api.clients.geai.globant.com
PROXY_LLM_API_KEY=your-api-key-here
PROXY_LLM_MODEL=openai/gpt-4o
PROXY_PORT=3456

# --- JNJ Azure Proxy (Cloud PC) --------------------------------------------
JNJ_AZURE_ENDPOINT=https://genaiapimna.jnj.com/openai-chat
JNJ_AZURE_API_KEY=your-jnj-api-key-here
JNJ_AZURE_DEPLOYMENT=gpt-4o
JNJ_AZURE_API_VERSION=2024-10-21
JNJ_PROXY_PORT=3457
JNJ_PROXY_MAX_RETRIES=3
